# ─── Flow Configuration ────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# ─── X Account (Required) ──────────────────────────────────────────────────────
# Your X handle (without @)
X_HANDLE=yourhandle

# ─── Secrets Directory ─────────────────────────────────────────────────────────
# Where your X OAuth credentials are stored
SECRETS_DIR=./.secrets

# Filename of your OAuth credentials within SECRETS_DIR
X_CREDENTIALS_FILE=x-oauth.env

# OAuth 2.0 token file (auto-generated after first login)
X_OAUTH2_TOKEN_FILE=x-oauth2.env

# ─── OAuth Redirect (Required) ─────────────────────────────────────────────────
# Must EXACTLY match what's registered in your X Developer app
OAUTH_REDIRECT_URI=https://your-domain.com/oauth/callback

# ─── OpenClaw Gateway (Required) ───────────────────────────────────────────────
# Token for authenticating with your OpenClaw gateway
OPENCLAW_GATEWAY_TOKEN=your-openclaw-gateway-token-here

# URL of your OpenClaw gateway
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789

# ─── AI Model ──────────────────────────────────────────────────────────────────
# Model for content refinement (any model your OpenClaw supports)
REFINER_MODEL=anthropic/claude-sonnet-4-20250514

# ─── Server ────────────────────────────────────────────────────────────────────
# API server host and port
API_HOST=127.0.0.1
API_PORT=5120

# ─── Optional: Override Bundled post.py ────────────────────────────────────────
# Flow includes post.py in lib/ — only set this to use a different version
# POST_SCRIPT_PATH=/path/to/your/post.py
